# ============================================================
# AI Job Hunter Bot — Environment Variables
# Copy to infra/.env and fill in your values
# See docs/SETUP_KEYS.md for step-by-step instructions to get each key
# ============================================================

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
ADMIN_API_KEY=your_generated_admin_secret
SECRET_KEY=your_generated_jwt_secret
LOG_LEVEL=INFO

# ── Logging (local only) ──────────────────────────────────────────────────────
LOG_DIR=backend/logs
LOG_TO_FILE=true
LOG_ROTATION_MB=50

# ── Database — Local Docker PostgreSQL ────────────────────────────────────────
# Local Docker (default):
DATABASE_URL=postgresql+asyncpg://jobhunter:jobhunter@postgres:5432/jobhunter
POSTGRES_LOCAL=true
# Cloud alternative — Neon PostgreSQL (uncomment and set POSTGRES_LOCAL=false):
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# POSTGRES_LOCAL=false

# ── Redis — Local Docker (result backend + API cache) ─────────────────────────
# Local Docker (default):
REDIS_URL=redis://redis:6379
CELERY_RESULT_BACKEND=redis://redis:6379
# Cloud alternative — Upstash Redis (use rediss:// for TLS):
# REDIS_URL=rediss://default:password@your-endpoint.upstash.io:6379
# CELERY_RESULT_BACKEND=rediss://default:password@your-endpoint.upstash.io:6379

# ── RabbitMQ — Local Docker (task broker) ─────────────────────────────────────
# RabbitMQ handles all task queuing (jh_scraping_* / jh_cover_letter_* / jh_email_send).
# Redis is used only for result storage + caching.
# Local Docker (default):
RABBITMQ_URL=amqp://jobhunter:jobhunter@rabbitmq:5672/
# Cloud alternative — CloudAMQP (use amqps:// for TLS):
# RABBITMQ_URL=amqps://user:password@chameleon.rmq.cloudamqp.com/vhost
# Redis broker fallback (only used if RABBITMQ_URL is empty):
CELERY_BROKER_URL=redis://redis:6379

# ── Broker Routing ────────────────────────────────────────────────────────────
# Queue-based routing: specific queues use specific brokers
#   - RabbitMQ: jh_scraping_bulk, jh_scraping_realtime, jh_scraping_enrichment
#   - Redis: jh_jobs_maintenance, jh_cover_letter_*, jh_email_*
# See infra/worker.config.yml for per-worker broker assignments

# ── LLM — Groq ───────────────────────────────────────────────────────────────
# See docs/SETUP_KEYS.md → Section 3
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Dedicated model for high-volume job scoring. A smaller model (8b-instant) keeps
# the 70B model + token budget free for cover letters. Empty = reuse GROQ_MODEL.
GROQ_SCORING_MODEL=llama-3.1-8b-instant
# Rate limiting — shared Redis sliding window across all workers
GROQ_RPM=10           # requests/min for this model tier (free=10, paid=30+)
GROQ_TPM=12000        # tokens/min (informational; not enforced yet)
# Multi-key round-robin: comma-separated aliases (e.g. "key1,key2").
# Set actual keys as GROQ_API_KEY_KEY1=gsk_... GROQ_API_KEY_KEY2=gsk_...
GROQ_API_KEYS=        # leave empty to use single GROQ_API_KEY

# ── Embeddings — Ollama (local, no key needed) ────────────────────────────────
# For Docker: use http://ollama:11434 (Docker service name)
# For local dev: use http://localhost:11434
# First run: docker exec ollama ollama pull nomic-embed-text
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Vector DB ────────────────────────────────────────────────────────────────
# pgvector (default): durable, process-safe, HNSW-indexed ANN (migration 0011).
# local = JSON-file dev/test backend only (unsafe across worker processes).
VECTOR_DB_PROVIDER=pgvector
PINECONE_API_KEY=
PINECONE_ENV=us-east-1-aws
PINECONE_INDEX=job-embeddings

# ── Email ─────────────────────────────────────────────────────────────────────
# EMAIL_PROVIDER controls which adapter is used: brevo | mailtrap | smtp
# See docs/SETUP_KEYS.md → Section 4

# Brevo (production transactional email — recommended):
EMAIL_PROVIDER=brevo
BREVO_API_KEY=your_brevo_api_key_here
BREVO_FROM_EMAIL=jobs@yourdomain.com
BREVO_FROM_NAME=Job Application Bot
BREVO_WEBHOOK_SECRET=

# Mailtrap (sandbox testing — emails never leave Mailtrap):
# EMAIL_PROVIDER=mailtrap
# MAILTRAP_API_KEY=your_mailtrap_api_key
# MAILTRAP_FROM_EMAIL=test@example.com
# MAILTRAP_FROM_NAME=Job Application Bot
# MAILTRAP_SANDBOX=true
# MAILTRAP_INBOX_ID=123456

# SMTP fallback (Gmail, custom SMTP):
# EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Redirect all sends to this address for testing (leave empty for production):
EMAIL_TEST_OVERRIDE=

# ── Storage — Cloudflare R2 ──────────────────────────────────────────────────
# See docs/SETUP_KEYS.md → Section 5
S3_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
S3_BUCKET_NAME=jobhunter-resumes
S3_ACCESS_KEY=your_r2_access_key_id
S3_SECRET_KEY=your_r2_secret_access_key
S3_REGION=auto

# ── Scraper ──────────────────────────────────────────────────────────────────
PROXY_URL=
RESPECT_ROBOTS_TXT=true
DEFAULT_CRAWL_DELAY_SECONDS=2.0
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Snov.io — HR email discovery (step 5 of pipeline) ────────────────────────
# Sign up at https://snov.io → API Settings → grab Client ID + Client Secret
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# ── HR email provider quota limits ───────────────────────────────────────────
# Tracked in Redis (rl:hunter:daily, rl:snov:daily) to avoid burning credits.
# Set to 0 to disable quota tracking for a provider.
HUNTER_DAILY_QUOTA=1     # Hunter.io free: 25 searches/month ≈ 1/day
SNOV_DAILY_QUOTA=2       # Snov.io free: 50 searches/month ≈ 2/day

