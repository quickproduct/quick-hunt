# ============================================================
# AI Job Hunter Bot — Production Environment Variables
# Copy to infra/.env.prod and fill in all CHANGE_ME_ values
#
# Generate secrets:
#   openssl rand -hex 32   → for ADMIN_API_KEY, SECRET_KEY, JWT_SECRET
#   openssl rand -hex 16   → for POSTGRES_PASSWORD, RABBITMQ_DEFAULT_PASS
# ============================================================

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
ADMIN_API_KEY=CHANGE_ME_openssl_rand_hex_32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
LOG_LEVEL=WARNING

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_TO_FILE=false          # Log to stdout — captured by Docker json-file driver
LOG_DIR=/tmp/logs
LOG_ROTATION_MB=50

# ── PostgreSQL container credentials ─────────────────────────────────────────
# Used by both the postgres container (POSTGRES_*) and the app (DATABASE_URL)
POSTGRES_DB=jobhunter
POSTGRES_USER=jobhunter
POSTGRES_PASSWORD=CHANGE_ME_db_password

# ── Database connection (points to postgres container) ───────────────────────
DATABASE_URL=postgresql+asyncpg://jobhunter:CHANGE_ME_db_password@postgres:5432/jobhunter

# ── Redis (points to redis container) ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── RabbitMQ container credentials ───────────────────────────────────────────
RABBITMQ_DEFAULT_USER=jobhunter
RABBITMQ_DEFAULT_PASS=CHANGE_ME_rmq_password

# ── RabbitMQ connection (points to rabbitmq container) ───────────────────────
RABBITMQ_URL=amqp://jobhunter:CHANGE_ME_rmq_password@rabbitmq:5672/
# Redis fallback broker (used only if RABBITMQ_URL is empty)
CELERY_BROKER_URL=redis://redis:6379/0

# ── LLM — Groq ───────────────────────────────────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_RPM=10
GROQ_TPM=12000
GROQ_API_KEYS=

# ── Embeddings — Ollama (running as container) ────────────────────────────────
# After first deploy: docker compose ... exec ollama ollama pull nomic-embed-text
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Vector DB ────────────────────────────────────────────────────────────────
VECTOR_DB_PROVIDER=local
PINECONE_API_KEY=
PINECONE_ENV=us-east-1-aws
PINECONE_INDEX=job-embeddings
SCORE_THRESHOLD=60

# ── Dashboard build arg ───────────────────────────────────────────────────────
# Must match ADMIN_API_KEY above — baked into the Next.js image at build time
NEXT_PUBLIC_ADMIN_API_KEY=CHANGE_ME_openssl_rand_hex_32

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30
FRONTEND_URL=http://your-vps-ip-or-domain

# ── Email — Resend ────────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=jobs@yourdomain.com
RESEND_FROM_NAME=Job Application Bot
RESEND_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# SMTP fallback (only used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ── Storage — Cloudflare R2 ──────────────────────────────────────────────────
S3_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
S3_BUCKET_NAME=jobhunter-resumes
S3_ACCESS_KEY=your_r2_access_key_id
S3_SECRET_KEY=your_r2_secret_access_key
S3_REGION=auto

# ── Scraper ──────────────────────────────────────────────────────────────────
PROXY_URL=
RESPECT_ROBOTS_TXT=true
DEFAULT_CRAWL_DELAY_SECONDS=2.0
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
MAX_JOB_AGE_DAYS=60
SCRAPE_STRICT_DATE_MODE=false

# ── Snov.io — HR email discovery ─────────────────────────────────────────────
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# ── HR email provider quota limits ───────────────────────────────────────────
HUNTER_DAILY_QUOTA=1
SNOV_DAILY_QUOTA=2

# ── Automation kill switches ──────────────────────────────────────────────────
AUTO_SEND_ENABLED=false
EMAIL_TEST_OVERRIDE=
LANGCHAIN_ENABLED=true

# ── Billing — Razorpay ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Observability — Langfuse (optional) ──────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Worker scaling (override defaults with --scale or these vars) ─────────────
WORKER_SCRAPING_BULK_SCALE=1
WORKER_SCRAPING_REALTIME_SCALE=1
WORKER_ENRICHMENT_SCALE=1
WORKER_MAINTENANCE_SCALE=1
WORKER_COVER_BULK_SCALE=1
WORKER_COVER_RANKING_SCALE=1
WORKER_COVER_GENERATION_SCALE=1
WORKER_COVER_WORKFLOW_SCALE=1
WORKER_EMAIL_SCALE=1

# ── Worker concurrency ────────────────────────────────────────────────────────
WORKER_SCRAPING_BULK_CONCURRENCY=2
WORKER_SCRAPING_REALTIME_CONCURRENCY=5
WORKER_ENRICHMENT_CONCURRENCY=4
WORKER_MAINTENANCE_CONCURRENCY=2
WORKER_COVER_BULK_CONCURRENCY=2
WORKER_COVER_RANKING_CONCURRENCY=2
WORKER_COVER_GENERATION_CONCURRENCY=2
WORKER_COVER_WORKFLOW_CONCURRENCY=2
WORKER_EMAIL_CONCURRENCY=2
