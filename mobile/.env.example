# API Configuration
# The base URL for the backend API
# For development on iOS simulator: http://localhost:8000
# For development on Android emulator: http://10.0.2.2:8000
# For physical device: use your machine's IP address (e.g., http://192.168.1.100:8000)
# For production: your production API URL
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: Enable/disable debug logging
EXPO_PUBLIC_DEBUG_LOGGING=true

# Optional: Log level (info, warn, error, critical)
EXPO_PUBLIC_LOG_LEVEL=info
